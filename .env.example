# Ollama local (backend de LLM usado por server/controllers/chatController.ts)
# Instale: https://ollama.com  -- rode: 'ollama serve' + 'ollama pull fazendaavila2026/avila'
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="fazendaavila2026/avila:latest"

# Opcional: token GitHub para as ferramentas github_list_repos / github_create_issue
# (lido em server/controllers/toolController.ts)
VITE_GITHUB_TOKEN=""
