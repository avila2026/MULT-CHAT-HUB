# Chave de ativação do servidor (obrigatória — servidor não sobe sem este valor)
# Crie um arquivo apps/lite/.env.local (ignorado pelo git) com o valor real:
#   APP_ACTIVATION_SECRET="sua-chave-secreta"
APP_ACTIVATION_SECRET=""

# Ollama local (backend de LLM usado por server/controllers/chatController.ts)
# Instale: https://ollama.com  -- rode: 'ollama serve' + 'ollama pull fazendaavila2026/avila'
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="fazendaavila2026/avila:latest"

# Opcional: token GitHub para as ferramentas github_list_repos / github_create_issue
# (lido em server/controllers/toolController.ts — NÃO use prefixo VITE_ para não expor no bundle)
GITHUB_TOKEN=""

# LLM Cloud Providers — fallback server-side (configuração na UI do AgentConfig é preferida)
# Chaves inseridas na UI são passadas por request e têm prioridade sobre estas vars.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""
