# Gemini cloud (provedor padrão de LLM, usado em server/controllers/chatController.ts)
# Obtenha em: https://ai.google.dev (free tier disponível)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Fallback Ollama local (usado se GEMINI_API_KEY estiver vazio ou Gemini falhar)
# Instale em https://ollama.com e rode 'ollama serve' + 'ollama pull llama3.1:8b'
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# Opcional: token GitHub para as ferramentas github_list_repos / github_create_issue
# (lido em server/controllers/toolController.ts)
VITE_GITHUB_TOKEN=""
