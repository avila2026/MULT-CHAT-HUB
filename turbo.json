{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.example", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "server-dist/**", ".next/**", "!.next/cache/**"]
    },
    "build:lite": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "server-dist/**", "release/**"]
    },
    "build:frontend": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:electron": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "server-dist/**", "release/**"]
    },
    "build:cloud": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:lite": {
      "cache": false,
      "persistent": true
    },
    "dev:cloud": {
      "cache": false,
      "persistent": true
    }
  }
}
