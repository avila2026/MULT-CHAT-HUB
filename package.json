{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3001 --host=0.0.0.0",
    "build:frontend": "vite build",
    "build:server": "tsc server/index.ts --outDir server-dist --module ESNext --moduleResolution node --esModuleInterop --skipLibCheck",
    "build": "npm run build:frontend && npm run build:server",
    "preview": "vite preview",
    "clean": "rm -rf dist server-dist",
    "lint": "tsc --noEmit",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"npm run dev:all\" \"wait-on tcp:3000 tcp:3001 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.multchathub.app",
    "productName": "MULT CHAT HUB",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "server-dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "server-dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "javascript-lp-solver": "^0.4.24",
    "lucide-react": "^0.546.0",
    "ml-regression-multivariate-linear": "^2.0.4",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
