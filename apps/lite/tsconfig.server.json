{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "server-dist",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["server/**/*.ts", "src/lib/analyticalEngine.ts", "src/lib/providerAdapters.ts", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "release", "server-dist"]
}
